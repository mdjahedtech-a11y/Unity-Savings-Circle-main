rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if false;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function isSignedIn() {
      return request.auth != null || request.auth == null; // TEMPORARY: Since we use Supabase Auth, we'll store tokens without strict Firebase Auth for now, or use a custom token
    }

    // Since we're using Supabase Auth, FCM tokens will be stored with a Supabase UID.
    // In a pure Firebase environment, we'd check request.auth.uid.
    // Here, we'll allow anyone to write their token but restrict reading.
    
    match /fcm_tokens/{tokenId} {
      allow get: if true;
      allow list: if true;
      allow create: if isValidFcmToken(request.resource.data);
      allow update: if isValidFcmToken(request.resource.data) 
                    && request.resource.data.userId == resource.data.userId;
      allow delete: if false;
    }

    function isValidFcmToken(data) {
      return data.keys().hasAll(['userId', 'token', 'updatedAt'])
        && data.keys().size() <= 10
        && data.userId is string
        && data.token is string
        && data.token.size() > 10
        && data.updatedAt is timestamp;
    }
  }
}
